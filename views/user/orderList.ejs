<%- include('../partials/user/header') %>
<link rel="stylesheet" href="/css/user-style/orderList.css">

<div class="account-container">

  <!-- Sidebar -->
  <div class="account-sidebar">
    <h3 class="sidebar-title">My Account</h3>
    <ul class="sidebar-menu">
      <li><a href="/order" class="sidebar-link active"><i class="fas fa-shopping-bag"></i> Order</a></li>
      <li><a href="/wishlist" class="sidebar-link"><i class="fas fa-heart"></i> Wishlist</a></li>
      <li><a href="/address" class="sidebar-link"><i class="fas fa-map-marker-alt"></i> Address</a></li>
      <% if (!user.isGoogleUser) { %>
        <li><a href="/password" class="sidebar-link"><i class="fas fa-lock"></i> Password</a></li>
      <% } %>
      <li><a href="/account" class="sidebar-link"><i class="fas fa-user"></i> Account Detail</a></li>
      <li><a href="/wallet" class="sidebar-link"><i class="fas fa-wallet"></i> Wallet</a></li>
      <li><a href="/referral" class="sidebar-link"><i class="fas fa-share-alt"></i> Referral</a></li>
      <li><a href="/logout" class="sidebar-link"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
    </ul>
  </div>

  <!-- MAIN CONTENT -->
  <div class="orders-main-content">
    <div class="orders-card">

      <!-- Header + Search -->
      <div class="orders-header">
        <h2>Your Orders</h2>

        <form class="orders-search" method="GET" action="/order">
          <input 
            type="text"
            name="q"
            placeholder="Search by Order ID or product"
            value="<%= typeof q !== 'undefined' ? q : '' %>"
          >
          <button type="submit">Search</button>
        </form>
      </div>

      <% if (orders && orders.length > 0) { %>
        <div class="order-list">

          <% orders.forEach(function(order) { %>
            <div class="order-item">

              <!-- Thumbnail -->
              <div class="order-thumb">
                <% if (order.items.length > 0) { %>
                  <img src="/uploads/product/<%= order.items[0].productImage %>" class="cart-thumb">
                <% } else { %>
                  <div class="no-thumb">No Image</div>
                <% } %>
              </div>

              <!-- Order Info -->
              <div class="order-info">
                <div class="order-title">
                  <%= order.items && order.items.length > 0 ? order.items[0].productName : "Order" %>
                  <div class="order-id">Order ID: <%= order.orderId %></div>
                </div>

                <div class="order-meta">
                  Ordered On:
                  <%= new Date(order.orderDate).toLocaleDateString("en-GB") %>
                </div>

                <div class="order-amount">₹ <%= order.totalAmount %></div>
              </div>

              <!-- Status -->
              <div class="order-status">
                <span class="badge <%= order.orderStatus.toLowerCase() %>">
                  <%= order.orderStatus %>
                </span>
              </div>

              <!-- Review Section -->
              <% if (order.orderStatus === "Delivered") { %>
                <div class="review-toggle" onclick="toggleReview('<%= order._id %>')">
                  ⭐ Write Review for Items
                </div>

                <div class="review-items" id="review-box-<%= order._id %>" style="display:none;">
                  <% order.items.forEach(function(item) { %>
                    <div class="review-item-row">

                      <img src="/uploads/product/<%= item.productImage %>" class="review-thumb">

                      <div class="review-item-info">
                        <p><%= item.productName %></p>
                      </div>

                      <a href="/product/<%= item.productId %>/review" class="review-btn">
                        Write Review
                      </a>

                    </div>
                  <% }); %>
                </div>
              <% } %>

              <!-- Actions -->
              <div class="order-actions">
                <a href="/order/<%= order._id %>" class="btn">Details</a>

                <% if (order.orderStatus !== "Cancelled" && order.orderStatus !== "Delivered") { %>
                  <a href="/order/cancel/<%= order._id %>" class="btn btn-secondary">Cancel</a>
                <% } %>
              </div>

            </div>
          <% }); %>

        </div>

        <!-- Pagination -->
        <div class="pagination">
          <% if (pagination.totalPages > 1) { %>

            <% if (pagination.currentPage > 1) { %>
              <a href="?page=<%= pagination.currentPage - 1 %>" class="page-btn">Prev</a>
            <% } %>

            <% for (let i = 1; i <= pagination.totalPages; i++) { %>
              <a 
                href="?page=<%= i %>" 
                class="page-number <%= pagination.currentPage === i ? 'active' : '' %>">
                <%= i %>
              </a>
            <% } %>

            <% if (pagination.currentPage < pagination.totalPages) { %>
              <a href="?page=<%= pagination.currentPage + 1 %>" class="page-btn">Next</a>
            <% } %>

          <% } %>
        </div>

      <% } else { %>
        <p>No orders found</p>
      <% } %>

    </div>
  </div>

</div>

<script>
  function toggleReview(id) {
    const box = document.getElementById("review-box-" + id);
    box.style.display = box.style.display === "none" ? "block" : "none";
  }
</script>

<%- include('../partials/user/footer') %>