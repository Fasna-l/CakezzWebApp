<%- include('../partials/user/header') %>
  <link rel="stylesheet" href="/css/user-style/contact.css">

  <div class="contact-page">

    <!-- HERO SECTION -->
    <div class="contact-hero">
      <h1>Get in Touch with Cakez.in 🍰</h1>
      <p>
        Have questions about our cakes, orders, or delivery?
        Our team is happy to help you!
      </p>
    </div>


    <!-- CONTACT CARDS -->
    <div class="contact-cards">

      <!-- Call Card -->
      <div class="contact-card">
        <div class="icon-box">
          <i class="fas fa-phone"></i>
        </div>

        <h3>Reach Us</h3>

        <p>
          Talk directly with our team for cake orders, delivery updates,
          or any enquiry.
        </p>

        <a href="tel:+919036366226" class="contact-btn">
          Call Now
        </a>
      </div>


      <!-- Email Card -->
      <div class="contact-card">
        <div class="icon-box">
          <i class="fas fa-envelope"></i>
        </div>

        <h3>Email Us</h3>

        <p>
          Send us your feedback, event orders,
          or any enquiry. We'll reply soon.
        </p>

        <a href="mailto:cakez.in2027@gmail.com" class="contact-btn">
          Send Email
        </a>
      </div>


      <!-- Location Card -->
      <div class="contact-card">
        <div class="icon-box">
          <i class="fas fa-map-marker-alt"></i>
        </div>

        <h3>Our Outlets</h3>

        <p>
          Malappuram || Manjeri || Calicut || Alappuzha || TVM || Kochi
        </p>

        <a href="" target="_blank" class="contact-btn">
          View Location
        </a>
      </div>

    </div>

  </div>

  <%- include('../partials/user/footer') %>