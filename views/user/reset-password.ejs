<%- include('../partials/user/header') %>
  <link rel="stylesheet" href="/css/user-style/reset-password.css">
  <!--==============================Login page==============================================-->
  <main class="resetpassword-container">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12">
          <div class="resetpassword-card">
            <div class="row g-0">
              <!--Left: Illustration -->
              <div class="col-md-6">
                <section class="promo-section" aria-label="login illustration">
                  <img src="/images/login-side-image.png" alt="Delivery person giving a gift to a customer"
                    class="illustration-image" />
                </section>
              </div>

              <!--Right: Form -->
              <div class="col-md-6">
                <section class="form-section" aria-labelledby="resetpassword-title">
                  <h2 id="resetpassword-title" class="form-title">Login</h2>

                  <form id="resetpasswordForm" action="/reset-password" method="POST" novalidate> <!--novalidate-->

                    <div class="form-group">
                      <label class="form-label" for="password">new Password</label>
                      <input type="password" class="form-control" id="password" name="password"
                        placeholder="Enter new password" required />
                      <div id="error1" class="error-message"></div>
                    </div>


                    <div class="form-group">
                      <label class="form-label" for="confirmPassword">Re-Enter Password</label>
                      <input type="password" class="form-control" id="confirmPassword" name="confirmPassword"
                        placeholder="Confirm new password" required />
                      <div id="error2" class="error-message"></div>
                    </div>

                    <%if(locals.message && message.length>0){%>
                      <div class="alert alert-danger text-center">
                        <%=message%>
                      </div>
                      <%}%>

                        <button type="submit" class="btn btn-primary cakezz-primary-btn">Update Password</button>
                  </form>

                  <p class="login-link">
                    Back To
                    <a href="/login" class="link-pink">Login</a>
                  </p>
                </section>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const resetpasswordForm = document.getElementById("resetpasswordForm");
      const password = document.getElementById("password");
      const confirmPassword = document.getElementById("confirmPassword");
      const error1 = document.getElementById("error1");
      const error2 = document.getElementById("error2");

      function validatePassword() {
        const passVal = password.value.trim();
        const passPattern =
          /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$/;

        if (passVal === "") {
          error1.style.display = "block";
          error1.textContent = "Password is required";
        } else if (!passPattern.test(passVal)) {
          error1.style.display = "block";
          error1.textContent =
            "Password must be at least 8 characters long and include uppercase, lowercase, number, and special character";
        } else {
          error1.style.display = "none";
          error1.textContent = "";
        }
      }

      function validateConfirmPassword() {
        const passVal = password.value.trim();
        const confirmVal = confirmPassword.value.trim();

        if (confirmVal === "") {
          error2.style.display = "block";
          error2.textContent = "Please confirm your password";
        } else if (passVal !== confirmVal) {
          error2.style.display = "block";
          error2.textContent = "Passwords do not match";
        } else {
          error2.style.display = "none";
          error2.textContent = "";
        }
      }

      // Live validation
      password.addEventListener("input", validatePassword);
      confirmPassword.addEventListener("input", validateConfirmPassword);

      // On submit
      resetpasswordForm.addEventListener("submit", function (e) {
        validatePassword();
        validateConfirmPassword();

        if (error1.textContent || error2.textContent) {
          e.preventDefault();
        }
      });
    });
  </script>

  <%- include('../partials/user/footer') %>