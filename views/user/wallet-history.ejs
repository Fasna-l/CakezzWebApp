<%- include('../partials/user/header') %>
<link rel="stylesheet" href="/css/user-style/password.css">

<div class="account-container">
  <!-- Sidebar -->
  <div class="account-sidebar">
    <h3 class="sidebar-title">My Wallet</h3>
    <ul class="sidebar-menu">
      <li><a href="/order" class="sidebar-link"><i class="fas fa-shopping-bag"></i> Order</a></li>
      <li><a href="/wishlist" class="sidebar-link"><i class="fas fa-heart"></i> Wishlist</a></li>
      <li><a href="/address" class="sidebar-link"><i class="fas fa-map-marker-alt"></i> Address</a></li>
      <% if (!user.isGoogleUser) { %>
        <li><a href="/password" class="sidebar-link"><i class="fas fa-lock"></i> Password</a></li>
      <% } %>
      <li><a href="/account" class="sidebar-link"><i class="fas fa-user"></i> Account Detail</a></li>
      <li><a href="/wallet" class="sidebar-link active"><i class="fas fa-wallet"></i> Wallet</a></li>
      <li><a href="/referral" class="sidebar-link"><i class="fas fa-share-alt"></i> Referral</a></li>
      <li>
        <form action="/logout" method="POST" class="logout-form">
            <button type="submit" class="sidebar-link logout-btn">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
      </li>
      
    </ul>
  </div>

  <!-- Main Content -->
  
    <div class="account-content">
        <div class="account-header">
            <h2>TRANSACTION DETAILS</h2>
        </div>

        <table class="wallet-table">
            <thead>
                <tr>
                    <th>Transaction ID</th>
                    <th>Order Id</th>
                    <th>Description</th>
                    <th>Date</th>
                    <th>Withdrawal</th>
                    <th>Deposit</th>
                </tr>
            </thead>
            <tbody>
                <% transactions.forEach(tx => { %>
                <tr>
                    <td><%= tx._id %></td>
                    <td>
                        <% if (tx.orderId) { %>
                            <a href="/order/<%= tx.orderId._id %>">
                                <%= tx.orderId.orderId %>
                            </a>
                        <% } else { %>
                            -
                        <% } %>
                    </td>
                    <!-- <td><%= tx._id %></td> -->
                    <td><%= tx.description %></td>
                    <td><%= tx.createdAt.toDateString() %></td>

                <% if(tx.type === 'purchase' || tx.type === 'withdrawal'){ %>
                    <td>₹ <%= tx.amount %></td>
                    <td>-</td>
                <% } else { %>
                    <td>-</td>
                    <td>₹ <%= tx.amount %></td>
                <% } %>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <!--Pagination-->
        <div class="pagination-container">

            <% if (currentPage > 1) { %>
                <a href="/wallet/history?page=<%= currentPage - 1 %>" class="pagination-link prev">« Prev</a>
            <% } else { %>
                <span class="pagination-link disabled">« Prev</span>
            <% } %>

            <% 
                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
            %>

            <% if (startPage > 1) { %>
                <a href="/wallet/history?page=1" class="pagination-link">1</a>
                <% if (startPage > 2) { %>
                <span class="pagination-link disabled">...</span>
                <% } %>
            <% } %>

            <% for (let i = startPage; i <= endPage; i++) { %>
                <% if (i === currentPage) { %>
                <span class="pagination-link current"><%= i %></span>
                <% } else { %>
                <a href="/wallet/history?page=<%= i %>" class="pagination-link"><%= i %></a>
                <% } %>
            <% } %>

            <% if (endPage < totalPages) { %>
                <% if (endPage < totalPages - 1) { %>
                <span class="pagination-link disabled">...</span>
                <% } %>
                <a href="/wallet/history?page=<%= totalPages %>" class="pagination-link"><%= totalPages %></a>
            <% } %>

            <% if (currentPage < totalPages) { %>
                <a href="/wallet/history?page=<%= currentPage + 1 %>" class="pagination-link next">Next »</a>
            <% } else { %>
                <span class="pagination-link disabled">Next »</span>
            <% } %>

        </div>

        <p style="text-align:center;color:#aaa;font-size:13px;margin-top:8px;">
            Page <%= currentPage %> of <%= totalPages %>
        </p>
    </div>
</div>
<%- include('../partials/user/footer') %>
