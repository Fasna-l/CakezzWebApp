<%- include('../partials/user/header') %>
<link rel="stylesheet" href="/css/user-style/return-order.css">

<div class="account-container">

  <!-- Sidebar -->
  <div class="account-sidebar">
    <h3 class="sidebar-title">My Account</h3>
    <ul class="sidebar-menu">
      <li><a href="/order" class="sidebar-link active"><i class="fas fa-shopping-bag"></i> Order</a></li>
      <li><a href="/wishlist" class="sidebar-link"><i class="fas fa-heart"></i> Wishlist</a></li>
      <li><a href="/address" class="sidebar-link"><i class="fas fa-map-marker-alt"></i> Address</a></li>
      <% if (!user.isGoogleUser) { %>
        <li><a href="/password" class="sidebar-link"><i class="fas fa-lock"></i> Password</a></li>
      <% } %>
      <li><a href="/account" class="sidebar-link"><i class="fas fa-user"></i> Account Detail</a></li>
      <li><a href="/wallet" class="sidebar-link"><i class="fas fa-wallet"></i> Wallet</a></li>
      <li><a href="/referral" class="sidebar-link"><i class="fas fa-share-alt"></i> Referral</a></li>
      <li>
        <form action="/logout" method="POST" class="logout-form">
          <button type="submit" class="sidebar-link logout-btn">
            <i class="fas fa-sign-out-alt"></i> Logout
          </button>
        </form>
      </li>
    </ul>
  </div>

  <!-- Main Content -->
  <div class="orders-main-content">
    <div class="return-card">

      <h2>Return Order</h2>
      <p class="subtitle">Please tell us why you are returning this order (mandatory)</p>

      <form id="returnForm"  action="/order/return/<%= order._id %>" method="POST" class="return-form" novalidate>

        <label for="reason">Return Reason <span class="required">*</span></label>
        <textarea
          id="reason"
          name="reason"
          rows="6"
          placeholder="Explain the reason for return (required)..."></textarea>
        <p id="reasonError" style="color: red; font-size: 14px; margin-top: 4px;"></p>

        <div class="return-buttons">
          <button type="submit" class="btn btn-primary">Submit Return Request</button>
          <a href="/order/<%= order._id %>" class="btn btn-secondary">Go Back</a>
        </div>

      </form>

    </div>
  </div>
</div>

<script>
document.getElementById("returnForm").addEventListener("submit", function(e) {
    const reason = document.getElementById("reason").value.trim();
    const error = document.getElementById("reasonError");

    if (reason === "") {
        e.preventDefault();  // stop form submit
        error.textContent = "Please enter a valid return reason.";
        return false;
    } else {
        error.textContent = "";
    }
});

// Remove error when user types
document.getElementById("reason").addEventListener("input", function() {
    document.getElementById("reasonError").textContent = "";
});
</script>

<%- include('../partials/user/footer') %>
