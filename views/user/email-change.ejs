<%- include('../partials/user/header') %>
<link rel="stylesheet" href="/css/user-style/forgot-password.css">

<main class="forgotpassword-container">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12">
        <div class="forgotpassword-card">
          <div class="row g-0">

            <div class="col-md-6">
              <section class="promo-section" aria-label="email change illustration">
                <img src="/images/login-side-image.png" alt="Illustration" class="illustration-image" />
              </section>
            </div>

            <div class="col-md-6">
              <section class="form-section" aria-labelledby="changeemail-title">
                <h2 id="changeemail-title" class="form-title">Change Email</h2>

                <form id="emailChangeForm" action="/verify-email-change" method="POST" novalidate>

                  <div class="form-group">
                    <label class="form-label" for="oldEmail">Current Email</label>
                    <input type="email" class="form-control" id="oldEmail" name="oldEmail" placeholder="Enter your current email" required />
                    <div id="errorOld" class="error-message"></div>
                  </div>

                  <div class="form-group">
                    <label class="form-label" for="newEmail">New Email</label>
                    <input type="email" class="form-control" id="newEmail" name="newEmail" placeholder="Enter new email" required />
                    <div id="errorNew" class="error-message"></div>
                  </div>

                  <% if (locals.message && message.length > 0) { %>
                    <div class="alert alert-danger text-center"><%= message %></div>
                  <% } %>

                  <button type="submit" class="btn btn-primary cakezz-primary-btn">Send OTP</button>
                </form>

                <p class="login-link">
                  Back To 
                  <a href="/account" class="link-pink">Profile</a>
                </p>
              </section>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</main>

