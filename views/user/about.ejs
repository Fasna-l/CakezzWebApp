<%- include('../partials/user/header') %>

  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Poppins:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/user-style/about.css">

  <div class="about-container">

    <!-- HERO -->
    <div class="about-hero">
      <h1>About Cakezz 🍰</h1>
      <p>Baking happiness, Taste of love.</p>
    </div>

    <!-- STORY SECTION -->
    <div class="about-section">

      <div class="about-text">
        <h2>Our Story</h2>

        <p>
          Cakez.in was created with a simple dream — to make every celebration
          sweeter. What started as a small passion for baking quickly grew
          into a bakery loved by cake enthusiasts.
        </p>

        <p>
          We believe that every cake should not only look beautiful but
          also taste unforgettable. From birthdays to weddings,
          our cakes are crafted with love and the finest ingredients.
        </p>

      </div>

      <div class="about-image">
        <img src="/images/about page.jpg" alt="Cake Bakery">
      </div>

    </div>

    <!-- FEATURES -->
    <div class="about-features">

      <div class="feature-card">
        <i class="fas fa-birthday-cake"></i>
        <h3>Diversity of Cakes</h3>
        <p>We design cakes tailored for birthdays, weddings and special events.</p>
      </div>

      <div class="feature-card">
        <i class="fas fa-leaf"></i>
        <h3>Fresh Ingredients</h3>
        <p>Every cake is baked using high-quality and fresh ingredients.</p>
      </div>

      <div class="feature-card">
        <i class="fas fa-heart"></i>
        <h3>Baked with Love</h3>
        <p>Our team puts passion into every cake we create.</p>
      </div>

    </div>

  </div>

  <%- include('../partials/user/footer') %>