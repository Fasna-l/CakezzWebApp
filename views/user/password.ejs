<%- include('../partials/user/header') %>
<link rel="stylesheet" href="/css/user-style/password.css">

<div class="account-container">
  <!-- Sidebar -->
  <div class="account-sidebar">
    <h3 class="sidebar-title">My Account</h3>
    <ul class="sidebar-menu">
      <li><a href="/order" class="sidebar-link"><i class="fas fa-shopping-bag"></i> Order</a></li>
      <li><a href="/wishlist" class="sidebar-link"><i class="fas fa-heart"></i> Wishlist</a></li>
      <li><a href="/address" class="sidebar-link"><i class="fas fa-map-marker-alt"></i> Address</a></li>
      <% if (!user.isGoogleUser) { %>
        <li><a href="/password" class="sidebar-link active"><i class="fas fa-lock"></i> Password</a></li>
      <% } %>
      <li><a href="/account" class="sidebar-link"><i class="fas fa-user"></i> Account Detail</a></li>
      <li><a href="/wallet" class="sidebar-link"><i class="fas fa-wallet"></i> Wallet</a></li>
      <li><a href="/referral" class="sidebar-link"><i class="fas fa-share-alt"></i> Referral</a></li>
      <li><a href="/logout" class="sidebar-link"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
    </ul>
  </div>

  <!-- Main Content -->
  <div class="account-content">
    <div class="account-header">
      <h2>CHANGE PASSWORD</h2>
    </div>

    <form id="changePassForm" method="POST" action="/password" novalidate class="address-form">
      <div class="form-group">
        <label>Old Password</label>
        <input type="password" name="oldpassword" id="oldpassword" required>
        <span class="error-message" id="oldPassError"></span>
      </div>

      <!-- <div class="login-options">
        <a href="/forgot-password" class="forgot-password">Forgot Password?</a>
      </div> -->

      <div class="form-group">
        <label>New Password</label>
        <input type="password" name="newpassword" id="newpassword" required>
        <span class="error-message" id="newPassError"></span>
      </div>

      <div class="form-group">
        <label>Confirm Password</label>
        <input type="password" name="Confirmpassword" id="Confirmpassword" required>
        <span class="error-message" id="ConfirmpassError"></span>
      </div>

      <div class="form-actions">
        <button type="submit" class="save-btn">CHANGE PASSWORD</button>
      </div>
    </form>
  </div>
</div>

<!-- Hidden div for server messages -->
<div id="serverMessages"
  data-success="<%= typeof successMessage !== 'undefined' ? successMessage : '' %>"
  data-error="<%= typeof message !== 'undefined' ? message : '' %>">
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {
  const form = document.getElementById("changePassForm");
  const oldPass = document.getElementById("oldpassword");
  const newPass = document.getElementById("newpassword");
  const confirmPass = document.getElementById("Confirmpassword");

  const errorOld = document.getElementById("oldPassError");
  const errorNew = document.getElementById("newPassError");
  const errorConfirm = document.getElementById("ConfirmpassError");

  // --- Validate Password Fields ---
  function validatePasswordField(input, errorDiv) {
    const pass = input.value.trim();
    const pattern =
      /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$/;

    if (pass === "") {
      errorDiv.textContent = "Password is required";
      errorDiv.style.display = "block";
      return false;
    } else if (!pattern.test(pass)) {
      errorDiv.textContent =
        "Must include uppercase, lowercase, number, and special character (min 8 chars)";
      errorDiv.style.display = "block";
      return false;
    } else {
      errorDiv.textContent = "";
      errorDiv.style.display = "none";
      return true;
    }
  }

  // --- Validate Confirm Password ---
  function validateConfirmPassword() {
    if (newPass.value.trim() !== confirmPass.value.trim()) {
      errorConfirm.textContent = "Passwords do not match";
      errorConfirm.style.display = "block";
      return false;
    } else {
      errorConfirm.textContent = "";
      errorConfirm.style.display = "none";
      return true;
    }
  }

  // --- Form Submit ---
  console.log("✅ Script loaded, waiting for submit...");
  if (form) {
    form.addEventListener("submit", function (e) {
      console.log("🟢 Form submitted to /password");
      const validOld = validatePasswordField(oldPass, errorOld);
      const validNew = validatePasswordField(newPass, errorNew);
      const validConfirm = validateConfirmPassword();

      if (!validOld || !validNew || !validConfirm) {
        e.preventDefault();
      }
    });
  } else {
    console.error("❌ Form not found in DOM!");
  }

  // --- Live Validation ---
  newPass.addEventListener("input", () => validatePasswordField(newPass, errorNew));
  confirmPass.addEventListener("input", validateConfirmPassword);

  // --- SweetAlert from Server Response ---
  const msgDiv = document.getElementById("serverMessages");
  if (msgDiv) {
    const successMsg = msgDiv.dataset.success;
    const errorMsg = msgDiv.dataset.error;

    if (successMsg) {
      Swal.fire({
        icon: "success",
        title: successMsg,
        showConfirmButton: false,
        timer: 1500
      });
    } else if (errorMsg) {
      Swal.fire({
        icon: "error",
        title: errorMsg,
        showConfirmButton: false,
        timer: 1800
      });
    }
  }
});
</script>

<%- include('../partials/user/footer') %>
