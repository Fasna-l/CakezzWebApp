<%- include('../partials/user/header') %>

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<!--==================== MAIN CONTENT SECTION ====================-->

<!-- Hero Section-->
<section class="hero-section">
  <div class="container">
    <div class="hero-banner-container">
      <img src="/images/banner image.jpg" alt="banner image" class="img-fluid" />
      <button class="hero-shop-now-btn" onclick="window.location.href='/shop'">Shop Now</button>
    </div>
  </div>
</section>

<!-- Cakes Section (Latest Products – 1 kg check) -->
<section class="cakes-section">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="section-title mb-1">Cakes</h2>
      <p class="section-subtitle mb-3">Dreamy cakes for every occasion</p>
      <div class="d-flex justify-content-end">
        <a href="/shop" class="view-all-btn">VIEW ALL</a>
      </div>
    </div>

    <div class="row">
      <% latestProducts.forEach(product => { 
           const oneKgVariant = product.variants && product.variants.length > 0 ? product.variants[0] : null;
      %>
        <div class="col-lg-3 col-md-6">
          <div class="cake-card">
            <div class="wishlist-icon <%= wishlistProductIds?.includes(product._id.toString()) ? 'active' : '' %>"
              data-product-id="<%= product._id %>">
              <i class="fa-heart"></i>
              <!-- <i class="far fa-heart"></i> -->
            </div>

            <!-- <div class="wishlist-icon"><i class="far fa-heart"></i></div> -->
            <!-- <div class="wishlist-icon" data-product-id="<%= product._id %>">
              <i class="far fa-heart"></i>
            </div> -->


            <a href="/product/<%= product._id %>">
              <img src="/uploads/product/<%= product.productImage[0] %>" alt="<%= product.productName %>" />
            </a>

            <div class="cake-card-body">
              <h5 class="cake-card-title"><%= product.productName %></h5>

              <p class="cake-card-subtitle">
                Starting from ₹ <%= oneKgVariant?.price || 'N/A' %>
              </p>

              <% if (!oneKgVariant || oneKgVariant.stock <= 0) { %>
                <p style="color:red; font-weight:600;">Sold Out (1 kg)</p>
              <% } %>

              <button 
                class="cake-add-to-cart-btn"
                data-product-id="<%= product._id %>"
                data-size="1kg"
                data-qty="1"
                <%= (!oneKgVariant || oneKgVariant.stock <= 0) ? 'disabled' : '' %>>
  
                <i class="fas fa-shopping-cart"></i>
                <%= (!oneKgVariant || oneKgVariant.stock <= 0) ? 'Out of Stock' : 'Add to Cart' %>
              </button>

            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Bestsellers Section – check 3 kg / highest variant -->
<section class="bestsellers-section">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="section-title mb-0">Bestsellers</h2>
      <a href="/shop" class="view-all-grey">VIEW ALL</a>
    </div>

    <div class="swiper mySwiper">
      <div class="swiper-wrapper">
        <% bestProducts.forEach(product => { 
             const threeKgVariant = product.variants && product.variants.length > 0 
               ? product.variants[product.variants.length - 1] 
               : null;
        %>
          <div class="swiper-slide">
            <div class="product-card">
              
              <!-- <div class="wishlist-icon" data-product-id="<%= product._id %>"> -->
              <div class="wishlist-icon <%= wishlistProductIds?.includes(product._id.toString()) ? 'active' : '' %>"
                data-product-id="<%= product._id %>">
                <i class="fa-heart"></i>
                <!-- <i class="far fa-heart"></i> -->
              </div>


              <a href="/product/<%= product._id %>">
                <img src="/uploads/product/<%= product.productImage[0] %>" alt="<%= product.productName %>">
              </a>

              <div class="price-container">
                ₹<%= threeKgVariant?.price || product.maxPrice || 'N/A' %>
              </div>

              <% if (!threeKgVariant || threeKgVariant.stock <= 0) { %>
                <p style="color:red; font-weight:600;">Sold Out (3 kg)</p>
              <% } %>

              <div class="product-card-body">
                <button 
                  class="add-to-cart-btn mb-3"
                  data-product-id="<%= product._id %>"
                  data-size="3kg"
                  data-qty="1"
                  <%= (!threeKgVariant || threeKgVariant.stock <= 0) ? 'disabled' : '' %>>
  
                  <i class="fas fa-shopping-cart"></i>
                  <%= (!threeKgVariant || threeKgVariant.stock <= 0) ? 'Out of Stock' : 'Add to Cart' %>
                </button>

                <h5 class="product-title"><%= product.productName %></h5>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
  <div class="container">
    <div class="row">
      <div class="col-12 text-center">
        <h2 class="cta-pink-text">VISIT & EXPERIENCE</h2>
        <p class="cta-black-text">OUR SERVICES IN YOUR CITY</p>
      </div>
    </div>
  </div>
</section>

<!--==================== END MAIN CONTENT SECTION ====================-->
<script>
  var swiper = new Swiper(".mySwiper", {
    slidesPerView: 4,
    spaceBetween: 20,
    loop: true,
    autoplay: { delay: 3000, disableOnInteraction: false },
    navigation: { nextEl: ".swiper-button-next", prevEl: ".swiper-button-prev" },
    breakpoints: { 1024: { slidesPerView: 4 }, 768: { slidesPerView: 2 }, 480: { slidesPerView: 1 } }
  });
</script>

<%- include('../partials/user/footer') %>
