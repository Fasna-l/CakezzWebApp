<%- include('../partials/admin/header') %>
<link rel="stylesheet" href="/css/admin-style/addProducts.css">

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">


<div class="dashboard-container">
  <div class="dashboard-wrapper">
    <%- include('../partials/admin/sidebar') %>

    <div class="edit-product-container">
      <h2 class="page-title">Edit Product</h2>

      <!--  Only ONE onsubmit event -->
      <form action="/admin/editProduct/<%=product._id%>" method="POST" enctype="multipart/form-data" class="edit-product-form" onsubmit="submitProductForm(event)" novalidate>
        <input type="hidden" name="page" value="<%= page %>">
        <!-- Product Name -->
        <div class="form-group">
          <label>Product Name</label>
          <input type="text" name="productName" value="<%=product.productName%>" placeholder="Enter product name">
          <div id="name-error" class="error-message"></div>
        </div>

        <!-- Description -->
        <div class="form-group">
          <label>Description</label>
          <textarea placeholder="Enter product description" name="description" id="description"><%= product.description %></textarea>
          <div id="description-error" class="error-message"></div>
        </div>

        <!-- Category -->
        <div class="form-group">
          <label>Category</label>
          <select name="category">
            <option value="">Select Category</option>
              <% cat.forEach(category => { %>
                <option value="<%= category._id %>" 
                  <%= product.category && product.category.toString() === category._id.toString() ? 'selected' : '' %>>
                  <%= category.categoryName %>
                </option>
              <% }) %>
          </select>
          <div id="category-error" class="error-message"></div>
        </div>

        <!-- Variants -->
        <h3 class="section-title">Variants</h3>
        <% ['1kg','2kg','3kg'].forEach((size, index) => { %>
        <div class="variant-group">
          <div class="size-box"><%= size %></div>
          <div class="variant-inputs">
            <input type="number" name="variants[<%= index %>][stock]" value="<%= product.variants?.[index]?.stock || '' %>" placeholder="Stock" min="0">
            <input type="number" step="0.01" name="variants[<%= index %>][price]" value="<%= product.variants?.[index]?.price || '' %>" step="0.01" placeholder="Price" min="0">
          </div>
        </div>
        <% }) %>
        <div id="variant-error" class="error-message"></div>

        <!-- Images -->
        <div class="form-group">
          <label>Upload Product Images</label>
          <input type="file" name="productImage" id="productImageInput" multiple accept="image/*">
          <div id="images-error" class="error-message"></div>
        </div>

        <!--  Image Preview -->
        <div id="preview-container" style="display:flex; gap:10px; flex-wrap:wrap;"></div>

        <!-- ✅ Load Existing Server Images into Preview (NO MORE RED ERROR) -->
        <!-- <script>
          document.addEventListener("DOMContentLoaded", function () {
            const previewContainer = document.getElementById('preview-container');

            // ✅ SAFELY PASS IMAGES FROM SERVER (fixed to avoid IDE red error)
            const existingImages = JSON.parse('<%- JSON.stringify(product.images || []) %>'); // ✅ CHANGED

            existingImages.forEach((imgUrl) => {
              const div = document.createElement('div');
              div.style.position = 'relative';

              div.innerHTML = `
                <img src="/uploads/<%= product._id %>/${imgUrl}"
                     style="width:90px;height:90px;object-fit:cover;border-radius:6px;" />
                <button type="button" class="deleteExisting" data-name="${imgUrl}"
                  style="position:absolute;top:0;right:0;background:red;color:white;
                  border:none;border-radius:50%;height:20px;width:20px;cursor:pointer;">
                  ✖
                </button>
              `;

              previewContainer.appendChild(div);

              // ✅ Push to originalFiles so validation doesn't fail
              if (!originalFiles.includes(imgUrl)) {
                originalFiles.push(imgUrl);
              }
            });
          });
        </script> -->


        <!-- Cropper Modal -->
        <div id="cropperModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; 
                       background:rgba(0,0,0,0.7); justify-content:center; align-items:center; z-index:1000;">
            <div style="background:#fff; padding:20px; border-radius:10px; text-align:center;">
                <img id="crop-image" style="max-width:400px; max-height:400px; display:block; margin:auto;">
        
                <!-- Buttons Row -->
                <div style="margin-top:10px; display:flex; justify-content:center; gap:10px;">
                    <button id="cropBtn" type="button" style="padding:10px 20px; background:#4a90e2; color:#fff; border:none; border-radius:5px; cursor:pointer;">
                        Crop & Save
                    </button>
                    <button type="button" onclick="closeCropperModal()" style="padding:10px 20px; background:#aaa; color:#fff; border:none; border-radius:5px; cursor:pointer;">
                        Cancel
                    </button>
                </div>
            </div>
        </div>


        <!-- Submit -->
        <button type="submit" class="btn-submit">Update Product</button>

      </form>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script>
/* ✅ Global arrays */
let originalFiles = [];
let croppedFiles = [];
let currentIndex = -1;
let cropper = null;
let removedImages = [];

/* ✅ Make validation & submit functions global */
window.submitProductForm = submitProductForm;
window.validateProductForm = validateProductForm;

/* ✅ Validation Function (GLOBAL) */
function validateProductForm() {
  clearErrors();
  let isValid = true;

  const productName = document.getElementsByName('productName')[0].value.trim();
  const description = document.getElementsByName('description')[0].value.trim();
  const category = document.getElementsByName('category')[0].value;

  if (!productName) {
    showError('name-error', 'Please enter product name.');
    isValid = false;
  } else if (!/^[a-zA-Z0-9\s]+$/.test(productName)) {
    showError('name-error', 'Name can include letters, numbers & spaces only.');
    isValid = false;
  }

  if (!description) {
    showError('description-error', 'Please enter product description.');
    isValid = false;
  } else if (description.length < 10) {
    showError('description-error', 'Description must be at least 10 characters.');
    isValid = false;
  }

  if (!category) {
    showError('category-error', 'Please select a category.');
    isValid = false;
  }

  document.querySelectorAll(".variant-group").forEach((variant) => {
    const stock = variant.querySelector("input[name*='stock']").value;
    const price = variant.querySelector("input[name*='price']").value;
    if (stock === '' || Number(stock) < 0 || price === '' || Number(price) <= 0) {
      showError('variant-error', 'Please fill valid stock and price for all variants.');
      isValid = false;
    }
  });

  if (originalFiles.length < 3) {
    showError('images-error', 'Please keep at least 3 product images (existing or new).');
    isValid = false;
  }

  return isValid;
}

/* ✅ Error Handling */
function showError(id, message) {
  document.getElementById(id).innerText = message;
  document.getElementById(id).style.display = 'block';
}

function clearErrors() {
  document.querySelectorAll('.error-message').forEach(el => {
    el.innerText = '';
    el.style.display = 'none';
  });
}

/* ✅ DOM Loaded Functions */
document.addEventListener("DOMContentLoaded", function () {
  const fileInput = document.getElementById('productImageInput');
  const previewWrap = document.getElementById('preview-container');
  const modal = document.getElementById('cropperModal');
  const cropImg = document.getElementById('crop-image');
  const cropBtn = document.getElementById('cropBtn');

  /* ✅ 1. Load existing images properly */
  //const existingImages = JSON.parse('<%- JSON.stringify(product.images || []) %>');
  const existingImages = JSON.parse('<%- JSON.stringify(product.productImage || []) %>');

  existingImages.forEach(imgUrl => {
    addImageToPreview(imgUrl, true); // true = from server
    originalFiles.push(imgUrl);
  });

  /* ✅ 2. When user uploads new images */
  fileInput.addEventListener('change', (e) => {
    const newFiles = Array.from(e.target.files);
    newFiles.forEach(file => {
      originalFiles.push(file);
      croppedFiles.push(null);
      addImageToPreview(file, false); // false = new upload
    });
  });

  /* ✅ Function to show image in preview */
  function addImageToPreview(file, isServerImage) {
    const imgSrc = isServerImage
      ? `/uploads/product/${file}`
      : URL.createObjectURL(file);

    const div = document.createElement('div');
    div.style.position = 'relative';
    div.innerHTML = `
      <img src="${imgSrc}" style="width:90px;height:90px;object-fit:cover;border-radius:6px;cursor:pointer;" />
      <button type="button" class="deleteImage" 
        style="position:absolute;top:0;right:0;background:red;color:white;
        border:none;border-radius:50%;height:20px;width:20px;cursor:pointer;">✖</button>
    `;

    //  If clicked, crop image
    div.querySelector('img').addEventListener('click', () => {
      const index = Array.from(previewWrap.children).indexOf(div);
      openCropper(index);
    });

    //  If delete button clicked
    div.querySelector('.deleteImage').addEventListener('click', () => {
      const index = Array.from(previewWrap.children).indexOf(div);
      const imageToDelete = originalFiles[index];

    // ✅ If image was from server (old), store it for removal
      if (typeof imageToDelete === "string") {
      //removedImages.push(imageToDelete);
      removedImages.push(`/uploads/product/${imageToDelete}`);
      }
  
  // ✅ Remove image from arrays & UI
      
      originalFiles.splice(index, 1);
      croppedFiles.splice(index, 1);
      div.remove();
    });

    previewWrap.appendChild(div);
  }

  /* ✅ Open Cropper */
  function openCropper(idx) {
    currentIndex = idx;
    modal.style.display = 'flex';
    const img = originalFiles[idx];
    cropImg.src = typeof img === 'string'
      ? img.startsWith("/uploads") ? img : `/uploads/product/${img}`
      : URL.createObjectURL(img);


    if (cropper) cropper.destroy();
    cropper = new Cropper(cropImg, { aspectRatio: 1, viewMode: 1 });
  }

  /* ✅ Save crop */
  cropBtn.addEventListener('click', async () => {
    if (!cropper) return;
    const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
    const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.85));
    const newFile = new File([blob], `cropped_${Date.now()}.jpg`, { type: 'image/jpeg' });

    originalFiles[currentIndex] = newFile;
    croppedFiles[currentIndex] = newFile;
    cropper.destroy();
    modal.style.display = 'none';
    
    previewWrap.innerHTML = '';
    originalFiles.forEach((file, i) => addImageToPreview(file, typeof file === 'string'));
  });

  // ✅ Close modal if clicked outside
  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      if (cropper) cropper.destroy();
      modal.style.display = 'none';
    }
  });

});
async function submitProductForm(event) {
  event.preventDefault(); // Stop normal form submission

  if (!validateProductForm()) return; // Stop if form is invalid

  const formData = new FormData();
  formData.append("productName", document.querySelector("input[name='productName']").value);
  formData.append("description", document.querySelector("textarea[name='description']").value);
  formData.append("category", document.querySelector("select[name='category']").value);
  formData.append("removedImages", JSON.stringify(removedImages));
  formData.append("page", document.querySelector("input[name='page']").value);


  // ✅ Add variant data
  document.querySelectorAll(".variant-group").forEach((variant, index) => {
    formData.append(`variants[${index}][stock]`, variant.querySelector("input[name*='stock']").value);
    formData.append(`variants[${index}][price]`, variant.querySelector("input[name*='price']").value);
  });

  // ✅ Add updated images (only File objects are sent to backend)
  originalFiles.forEach((file, idx) => {
    if (file instanceof File) {
      formData.append("productImage", file);
    }
  });

  // ✅ Add deleted images if needed later
  // formData.append("removedImages", JSON.stringify(removedImages)); // (optional if deleting from server)

  try {
    const response = await fetch(`/admin/editProduct/<%= product._id %>`, {
      method: "POST",
      body: formData
    });

    const result = await response.json();

    if (result.success) {
      Swal.fire({
        icon: "success",
        title: "✅ Product Updated Successfully!",
        timer: 1500,
        showConfirmButton: false
      }).then(() => {
        window.location.href = result.redirectUrl;
        //window.location.href = "/admin/products";
      });
    } else {
      Swal.fire({
        icon: "error",
        title: "Update Failed",
        text: result.message
      });
    }
  } catch (error) {
    console.error(error);
    Swal.fire({
      icon: "error",
      title: "Something went wrong",
      text: "Please try again later."
    });
  }
}

</script>

<%- include('../partials/admin/footer') %>
