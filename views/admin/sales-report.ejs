<%- include('../partials/admin/header') %>
  <link rel="stylesheet" href="/css/admin-style/category.css">
  <link rel="stylesheet" href="/css/admin-style/sales-report.css">

  <div class="dashboard-container">
    <div class="dashboard-wrapper">
      <%- include('../partials/admin/sidebar') %>

        <div class="categories-container">

          <!-- Title + Export Buttons -->
          <div class="page-title"
            style="display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap;">
            <h2 style="margin:0;">Sales Report</h2>

            <div class="sales-export-group">
              <a href="/admin/sales-report/pdf?<%= new URLSearchParams({ search, range, startDate, endDate, status }).toString() %>"
                class="btn-add-category">PDF</a>
              <a href="/admin/sales-report/excel?<%= new URLSearchParams({ search, range, startDate, endDate, status }).toString() %>"
                class="btn-add-category">Excel</a>
            </div>
          </div>

          <!-- Filters -->
          <form action="/admin/sales-report" method="get"
            style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:20px;">

            <input type="text" name="search" class="sales-filter-input" placeholder="Search Order ID..."
              value="<%= search %>" style="width:200px;">

            <select name="range" class="sales-filter-input" style="width:150px;">
              <option value="">Filter By</option>
              <option value="today" <%=range==="today" ?"selected":"" %>>Today</option>
              <option value="week" <%=range==="week" ?"selected":"" %>>This Week</option>
              <option value="month" <%=range==="month" ?"selected":"" %>>This Month</option>
              <option value="year" <%=range==="year" ?"selected":"" %>>This Year</option>
              <option value="custom" <%=range==="custom" ?"selected":"" %>>Custom</option>
            </select>

            <select name="status" class="sales-filter-input" style="width:150px;">
              <option value="">All Status</option>
              <option value="Pending" <%=status==="Pending" ?"selected":"" %>>Pending</option>
              <!-- <option value="Payment Failed" <%= status==="Payment Failed"?"selected":"" %>>Payment Failed</option> -->
              <option value="Delivered" <%=status==="Delivered" ?"selected":"" %>>Delivered</option>
              <option value="Cancelled" <%=status==="Cancelled" ?"selected":"" %>>Cancelled</option>
              <option value="Returned" <%=status==="Returned" ?"selected":"" %>>Returned</option>
              <option value="Return Requested" <%=status==="Return Requested" ?"selected":"" %>>Return Requested
              </option>
            </select>

            <input type="date" name="startDate" class="sales-filter-input sales-date" style="width:140px;"
              value="<%= startDate %>">
            <input type="date" name="endDate" class="sales-filter-input sales-date" style="width:140px;"
              value="<%= endDate %>">

            <button class="search-button-text" type="submit" style="height:40px;">Apply</button>

            <% if (search || range || startDate || endDate || status) { %>
              <a href="/admin/sales-report" class="search-button-text"
                style="background:#777;text-decoration:none;height:40px;display:flex;align-items:center;">
                Clear
              </a>
              <% } %>

          </form>

          <!-- Table -->
          <div class="table-wrapper">
            <table class="categories-table">
              <thead>
                <tr>
                  <th>Order ID</th>
                  <th>Date</th>
                  <th>Payment</th>
                  <th>Subtotal</th>
                  <th>Discount</th>
                  <th>Grand Total(Paid)</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (sales.length) { %>
                  <% sales.forEach(o=> {
                    const paid = o.paymentMethod === "COD"
                    ? (o.totalAmount || 0)
                    : (o.payableAmount || o.totalAmount || 0);
                    %>
                    <tr>
                      <td>
                        <%= o.orderId %>
                      </td>
                      <td>
                        <%= new Date(o.orderDate).toLocaleDateString() %>
                      </td>
                      <td>
                        <%= o.paymentMethod %>
                      </td>
                      <td>₹<%= (o.subTotal || 0).toFixed(2) %>
                      </td>
                      <td>₹<%= ((o.offerDiscount || 0) + (o.couponDiscount || 0)).toFixed(2) %>
                      </td>
                      <td>₹<%= paid.toFixed(2) %>
                      </td>
                      <td>
                        <%= o.orderStatus %>
                      </td>
                    </tr>
                    <% }) %>
                      <% } else { %>
                        <tr>
                          <td colspan="7" style="text-align:center;">No sales data found</td>
                        </tr>
                        <% } %>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <div class="pagination-container">

            <% if (currentPage> 1) { %>
              <a class="pagination-link prev"
                href="/admin/sales-report?page=<%= currentPage - 1 %>&search=<%= search %>&range=<%= range %>&startDate=<%= startDate %>&endDate=<%= endDate %>&status=<%= status %>">
                « Prev
              </a>
              <% } else { %>
                <span class="pagination-link disabled">« Prev</span>
                <% } %>

                  <% function shouldShowPage(i, currentPage, totalPages) { return ( i===1 || i===2 || i===totalPages ||
                    i===totalPages - 1 || (i>= currentPage - 2 && i <= currentPage + 2) ); } %>

                      <% let lastShown=0; %>

                        <% for (let i=1; i <=totalPages; i++) { %>
                          <% if (shouldShowPage(i, currentPage, totalPages)) { %>

                            <% if (lastShown && i - lastShown> 1) { %>
                              <span class="pagination-link disabled">...</span>
                              <% } %>

                                <% if (i===currentPage) { %>
                                  <span class="pagination-link current">
                                    <%= i %>
                                  </span>
                                  <% } else { %>
                                    <a href="/admin/sales-report?page=<%= i %>&search=<%= search %>&range=<%= range %>&startDate=<%= startDate %>&endDate=<%= endDate %>&status=<%= status %>"
                                      class="pagination-link">
                                      <%= i %>
                                    </a>
                                    <% } %>

                                      <% lastShown=i; %>

                                        <% } %>
                                          <% } %>

                                            <% if (currentPage < totalPages) { %>
                                              <a class="pagination-link next"
                                                href="/admin/sales-report?page=<%= currentPage + 1 %>&search=<%= search %>&range=<%= range %>&startDate=<%= startDate %>&endDate=<%= endDate %>&status=<%= status %>">
                                                Next »
                                              </a>
                                              <% } else { %>
                                                <span class="pagination-link disabled">Next »</span>
                                                <% } %>

          </div>

        </div>
    </div>
  </div>

  <%- include('../partials/admin/footer') %>