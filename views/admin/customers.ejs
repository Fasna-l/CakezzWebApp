<%- include('../partials/admin/header') %>
<link rel="stylesheet" href="/css/admin-style/customer.css">

<div class="dashboard-container">
    <div class="dashboard-wrapper">
        <%- include('../partials/admin/sidebar') %>
        
        <!-- Main Content -->
        <div class="customers-container">

        <main class="main-content" id="mainContent">
    <!-- Header with Search -->
      <div class="content-header">
        <h2 class="content-title">Customers</h2>

        <form action="/admin/users" method="get" class="search-form">
        <div class="search-box">
            <input type="text" class="search-input" placeholder="Search customers..." name="search">
            <button class="search-button-text" type="submit">Search</button>
            <% if (search && search.trim() !== '') { %>
              <a href="/admin/users" class="search-button-text" style="background:#888;text-decoration: none;">Clear</a>
            <% } %>     
          </div>
        </form>
    </div>

    

  <!-- Filter Section -->
  <!-- <div class="filter-section">
    <div class="filter-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
      </svg>
    </div>
    <span class="filter-label">Filter By</span>
    <select class="filter-dropdown">
      <option value="all">All</option>
      <option value="blocked">Blocked</option>
      <option value="active">UnBlocked</option>
    </select>
  </div> -->

  <!-- Customers Table -->
  <div class="table-wrapper">
    <table class="customers-table">
      <thead>
        <tr>
          <th>S.No</th>
          <th>Name</th>
          <th>Email</th>
          
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <%for(let i=0;i<data.length;i++){%>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= data[i].name %></td>
          <td><%= data[i].email %></td>
        
        <td>
          <% if (data[i].isBlocked === false) { %>
            <button class="btn btn-danger" style="width: 80px;" 
            onclick="confirmAction(event, '/admin/blockCustomer?id=<%= data[i]._id %>', 'Block this user?')">Block
            </button>
          <% } else { %>
            <button 
            class="btn btn-success" 
            style="width: 80px;" 
            onclick="confirmAction(event, '/admin/unblockCustomer?id=<%= data[i]._id %>', 'Unblock this user?')">
            Unblock
            </button>
          <% } %>
        </td>
        </tr>
        <%}%>
        
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
 
  <div class="pagination-container" style="display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 25px;">

  <!-- Previous Button -->
  <% if (currentPage > 1) { %>
    <a href="/admin/users?page=<%= currentPage - 1 %>" class="pagination-link prev">« Prev</a>
  <% } else { %>
    <span class="pagination-link disabled">« Prev</span>
  <% } %>

  <!-- Page Numbers -->
  <% for (let i = 1; i <= totalPages; i++) { %>
    <% if (i === currentPage) { %>
      <span class="pagination-link current"><%= i %></span>
    <% } else { %>
      <a href="/admin/users?page=<%= i %>" class="pagination-link"><%= i %></a>
    <% } %>
  <% } %>

  <!-- Next Button -->
  <% if (currentPage < totalPages) { %>
    <a href="/admin/users?page=<%= currentPage + 1 %>" class="pagination-link next">Next »</a>
  <% } else { %>
    <span class="pagination-link disabled">Next »</span>
  <% } %>

</div>

<!-- Optional: Page indicator -->
<p style="text-align: center; color: #aaa; font-size: 13px; margin-top: 8px;">
  Page <%= currentPage %> of <%= totalPages %>
</p>


  </main>
    </div>
    </div>
</div>
<%- include('../partials/admin/footer') %>
<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  async function confirmAction(event, url, titleText) {
    event.preventDefault();

    const result = await Swal.fire({
      title: titleText,
      text: "Please Confirm Your Action",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Yes, confirm it!",
      background: "#2a2a2a",
      color: "#fff"
    });

    if (result.isConfirmed) {
      window.location.href = url;
    }
  }
</script>

