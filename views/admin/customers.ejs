<%- include('../partials/admin/header') %>
<link rel="stylesheet" href="/css/admin-style/customer.css">

<div class="dashboard-container">
    <div class="dashboard-wrapper">
        <%- include('../partials/admin/sidebar') %>
        
        <!-- Main Content -->
        <div class="customers-container">

        <main class="main-content" id="mainContent">
    <!-- Header with Search -->
      <div class="content-header">
        <h2 class="content-title">Customers</h2>

        <form action="/admin/users" method="get" class="search-form">
        <div class="search-box">
            <input type="text" class="search-input" placeholder="Search customers..." name="search">
            <button class="search-button-text" type="submit">Search</button>
            <% if (search && search.trim() !== '') { %>
              <a href="/admin/users" class="search-button-text" style="background:#888;text-decoration: none;">Clear</a>
            <% } %>     
          </div>
        </form>
    </div>

  <!-- Customers Table -->
  <div class="table-wrapper">
    <table class="customers-table">
      <thead>
        <tr>
          <th>S.No</th>
          <th>Name</th>
          <th>Email</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <%for(let i=0;i<data.length;i++){%>
        <tr>
          <td><%= (currentPage - 1) * 4 + i + 1 %></td>              
          <td><%= data[i].name %></td>
          <td><%= data[i].email %></td>
        
        <td>
          <% if (data[i].isBlocked === false) { %>
            <button class="btn btn-danger" style="width: 80px;" 
              onclick="confirmCustomer('<%= data[i]._id %>', 'block')">
              Block
            </button>

          <% } else { %>
            <button class="btn btn-success" style="width: 80px;" 
              onclick="confirmCustomer('<%= data[i]._id %>', 'unblock')">
              Unblock
            </button>

          <% } %>
        </td>
        </tr>
        <%}%>
        
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
    <div class="pagination-container">

      <% if (currentPage > 1) { %>
        <a href="/admin/users?page=<%= currentPage - 1 %>&search=<%= search || '' %>" class="pagination-link prev">« Prev</a>
      <% } else { %>
        <span class="pagination-link disabled">« Prev</span>
      <% } %>

      <% 
        const startPage = Math.max(1, currentPage - 2);
        const endPage = Math.min(totalPages, currentPage + 2);
      %>

      <% if (startPage > 1) { %>
        <a href="/admin/users?page=1&search=<%= search || '' %>" class="pagination-link">1</a>
        <% if (startPage > 2) { %>
          <span class="pagination-link disabled">...</span>
        <% } %>
      <% } %>

      <% for (let i = startPage; i <= endPage; i++) { %>
        <% if (i === currentPage) { %>
          <span class="pagination-link current"><%= i %></span>
        <% } else { %>
          <a href="/admin/users?page=<%= i %>&search=<%= search || '' %>" class="pagination-link"><%= i %></a>
        <% } %>
      <% } %>

      <% if (endPage < totalPages) { %>
        <% if (endPage < totalPages - 1) { %>
          <span class="pagination-link disabled">...</span>
        <% } %>
        <a href="/admin/users?page=<%= totalPages %>&search=<%= search || '' %>" class="pagination-link"><%= totalPages %></a>
      <% } %>

      <% if (currentPage < totalPages) { %>
        <a href="/admin/users?page=<%= currentPage + 1 %>&search=<%= search || '' %>" class="pagination-link next">Next »</a>
      <% } else { %>
        <span class="pagination-link disabled">Next »</span>
      <% } %>

    </div>
<!-- Optional: Page indicator -->
<p style="text-align: center; color: #aaa; font-size: 13px; margin-top: 8px;">
  Page <%= currentPage %> of <%= totalPages %>
</p>


  </main>
    </div>
    </div>
</div>
<%- include('../partials/admin/footer') %>
<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
async function confirmCustomer(userId, action) {
  const result = await Swal.fire({
    title: action === "block" ? "Block this user?" : "Unblock this user?",
    text: "Please confirm your action",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#3085d6",
    cancelButtonColor: "#d33",
    confirmButtonText: "Yes, confirm it!",
    background: "#2a2a2a",
    color: "#fff"
  });

  if (!result.isConfirmed) return;

  try {
    const response = await fetch(`/admin/customers/${userId}/${action}`, {
      method: "PATCH"
    });

    if (response.ok) {
      location.reload(); // refresh page
    } else {
      throw new Error("Failed");
    }
  } catch (error) {
    Swal.fire("Error", "Something went wrong", "error");
  }
}
</script>

