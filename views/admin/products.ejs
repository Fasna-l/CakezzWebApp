    <!-- ✅ Main Content -->
    <div class="products-container">
      <main class="main-content" id="mainContent">

        <div class="page-title">
            <h2>Products</h2>

            <!-- Add Product Button -->
            <a href="/admin/products/add" class="btn-add-product">Add Product</a>

            <!-- Search Form -->
            <form action="/admin/products" method="get" class="search-form">
                <div class="search-box">
                    <input type="text" class="search-input" placeholder="Search products..." name="search" value="<%= search || '' %>">
                    <button class="search-button-text" type="submit">Search</button>

                    <% if (search && search.trim() !== '') { %>
                        <a href="/admin/products" class="search-button-text" style="background:#888;text-decoration:none;">Clear</a>
                    <% } %>
                </div>
            </form>
        </div>

        


        <!-- ✅ Product Table -->
        <div class="table-wrapper">
