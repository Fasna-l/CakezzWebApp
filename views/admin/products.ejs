          <table class="categories-table">
            <thead>
                <tr>
                    <th>Sl.No</th>
                    <th>Image</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Action</th>
                    <th>Offer</th>
                    <th>Edit</th>
                </tr>
            </thead>

            <tbody>
                <% if (products && products.length > 0) { %>
                    <% products.forEach((product, index) => { %>
                        <tr>
                            <td><%= (currentPage - 1) * 3 + index + 1 %></td>

                            <!-- Product Image -->
                            <td>
                                <% if (product.productImage && product.productImage.length > 0) { %>
                                    <img src="/uploads/product/<%= product.productImage[0] %>" style="width:50px;height:50px;border-radius:5px;">
                                <% } else { %>
                                    <span>No Image</span>
                                <% } %>
                            </td>

                            <td><%= product.productName %></td>
                            <td><%= product.category ? product.category.categoryName  : "N/A" %></td>

                            <!-- <td>₹<%= product.variants[0]?.price || 0 %></td>
                            <td><%= product.variants[0]?.stock || 0 %></td> -->
                            <td>
                                1kg: ₹<%= product.variants[0]?.price || '-' %> <br>
                                2kg: ₹<%= product.variants[1]?.price || '-' %> <br>
                                3kg: ₹<%= product.variants[2]?.price || '-' %>
                            </td>

                            <td>
                                1kg: <%= product.variants[0]?.stock || '-' %> <br>
                                2kg: <%= product.variants[1]?.stock || '-' %> <br>
                                3kg: <%= product.variants[2]?.stock || '-' %>
                            </td>


                            <!-- Action Buttons -->
                            <td>
                                <div class="action-group">
                                    <!-- Block/UnBlock Button -->
                                    <% if (product.isBlocked === false) { %>
                                        <button class="btn btn-danger" style="width: 80px;" 
                                          onclick="confirmAction(event, '/admin/blockProduct?id=<%= product._id %>', 'Block this product?')">
                                            Block
                                        </button>
                                    <% } else { %>
                                        <button class="btn btn-success" style="width: 80px;" 
                                          onclick="confirmAction(event, '/admin/unblockProduct?id=<%= product._id %>', 'Unblock this product?')">
                                          Unblock
                                        </button>
                                    <% } %>
                                </div>
                            </td>

                            <!-- Offer Button (disabled for now) -->
                            <td>
                                <button class="btn-offer">Offer</button>
                            </td>
                            <td>
                              <!-- Edit Icon -->
                                    <a href="/admin/editProduct?id=<%= product._id %>" class="btn-edit">
                                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                        </svg>
                                    </a>
                            </td>
                        </tr>
                <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="9" style="text-align:center;">No Products Available</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        </div>

        <!-- ✅ Pagination -->
        <div class="pagination-container">
          <% if (currentPage > 1) { %>
            <a href="/admin/products?page=<%= currentPage - 1 %>" class="pagination-link">« Prev</a>
          <% } else { %>
            <span class="pagination-link disabled">« Prev</span>
          <% } %>

          <% for (let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
              <span class="pagination-link current"><%= i %></span>
            <% } else { %>
              <a href="/admin/products?page=<%= i %>" class="pagination-link"><%= i %></a>
            <% } %>
          <% } %>

          <% if (currentPage < totalPages) { %>
            <a href="/admin/products?page=<%= currentPage + 1 %>" class="pagination-link">Next »</a>
          <% } else { %>
            <span class="pagination-link disabled">Next »</span>
          <% } %>
        </div>
         <!-- Optional: Page indicator -->
        <p style="text-align: center; color: #aaa; font-size: 13px; margin-top: 8px;">
            Page <%= currentPage %> of <%= totalPages %>
        </p>

      </main>
    </div>

  </div>
</div>

<%- include('../partials/admin/footer') %>

<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  async function confirmAction(event, url, titleText) {
    event.preventDefault();

    const result = await Swal.fire({
      title: titleText,
      text: "Please Confirm Your Action",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Yes, confirm it!",
      background: "#2a2a2a",
      color: "#fff"
    });

    if (result.isConfirmed) {
      window.location.href = url;
    }
  }
</script>
