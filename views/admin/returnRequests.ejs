<%- include('../partials/admin/header') %>
    <link rel="stylesheet" href="/css/admin-style/orderlist.css">

    <div class="dashboard-container">
        <div class="dashboard-wrapper">
            <%- include('../partials/admin/sidebar') %>

                <div class="categories-container">

                    <div class="page-title">
                        <h2>Return Requests</h2>

                        <form action="/admin/return-requests" method="get" class="search-form">
                            <div class="search-box">
                                <input type="text" class="search-input"
                                    placeholder="Search by order id / product / user..." name="search"
                                    value="<%= search || '' %>">

                                <button class="search-button-text" type="submit">Search</button>

                                <% if (search && search.trim() !=='' ) { %>
                                    <a href="/admin/return-requests" class="clear-btn">Clear</a>
                                    <% } %>
                            </div>
                        </form>

                    </div>

                    <div class="table-wrapper">
                        <table class="customers-table">
                            <thead>
                                <tr>
                                    <th>ORDER ID</th>
                                    <th>USER NAME</th>
                                    <th>PRODUCT NAME</th>
                                    <th>DATE</th>
                                    <th>QTY</th>
                                    <th>STATUS</th>
                                    <th>RETURN REASON</th>
                                    <th>ACTION</th>
                                </tr>
                            </thead>

                            <tbody>

                                <% if (groupedOrders && groupedOrders.length> 0) { %>

                                    <% groupedOrders.forEach(order=> {
                                        const items = order.items;
                                        const first = order.first;

                                        const isFullOrderReturn = items.length === first.totalItemCount;
                                        %>

                                        <!-- MAIN ROW -->
                                        <tr style="background:#37383a; font-weight:600;">
                                            <td>
                                                <%= first.orderId %>
                                            </td>
                                            <td>
                                                <%= first.userName %>
                                            </td>

                                            <td colspan="3">
                                                <%= items.length===1 ? "Single Item Returned"
                                                    : "Multiple Items Returned" %>
                                            </td>
                                            <td>
                                                <span class="status-badge processing">Return Requested</span>
                                            </td>
                                            <td></td> <!-- RETURN REASON placeholder -->
                                            <td>
                                                <% if (isFullOrderReturn) { %>

                                                    <form
                                                        action="/admin/orders/<%= first.orderDbId %>/approve-return?_method=PATCH"
                                                        method="POST">
                                                        <button class="return-action-btn btn-approve">Approve
                                                            All</button>
                                                    </form>
                                                    <form
                                                        action="/admin/orders/<%= first.orderDbId %>/reject-return?_method=PATCH"
                                                        method="POST">
                                                        <button class="return-action-btn btn-reject">Reject All</button>
                                                    </form>

                                                    <% } %>

                                                        <a href="/admin/order-details/<%= first.orderDbId %>"
                                                            class="btn-view">
                                                            View Order
                                                        </a>
                                            </td>
                                        </tr>

                                        <!-- SUB ITEM ROWS -->
                                        <% items.forEach(item=> { %>
                                            <tr class="sub-item-row">
                                                <td></td>
                                                <td></td>

                                                <td>
                                                    <%= item.item.productName %>
                                                </td>
                                                <td>
                                                    <%= new Date(first.orderDate).toLocaleDateString("en-GB") %>
                                                </td>
                                                <td>
                                                    <%= item.item.quantity %>
                                                </td>
                                                <td>
                                                    <span class="status-badge processing">
                                                        <%= item.item.status %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <%= item.item.returnReason || "—" %>
                                                </td>

                                                <td>
                                                    <% if (!isFullOrderReturn) { %>
                                                        <form
                                                            action="/admin/orders/<%= first.orderDbId %>/items/<%= item.item._id %>/approve-return?_method=PATCH"
                                                            method="POST">
                                                            <button
                                                                class="return-action-btn btn-approve">Approve</button>
                                                        </form>
                                                        <form
                                                            action="/admin/orders/<%= first.orderDbId %>/items/<%= item.item._id %>/reject-return?_method=PATCH"
                                                            method="POST">
                                                            <button class="return-action-btn btn-reject">Reject</button>
                                                        </form>
                                                        <% } %>
                                                </td>
                                            </tr>
                                            <% }) %>

                                                <tr>
                                                    <td colspan="8" style="height:10px; background:#eee;"></td>
                                                </tr>

                                                <% }) %>

                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="7" style="text-align:center;">No return
                                                                requests found</td>
                                                        </tr>
                                                        <% } %>

                            </tbody>
                        </table>
                    </div>

                    <div class="pagination-container">

                        <% if (currentPage> 1) { %>
                            <a href="/admin/return-requests?page=<%= currentPage - 1 %>&search=<%= encodeURIComponent(search || '') %>"
                                class="pagination-link prev">« Prev</a>
                            <% } else { %>
                                <span class="pagination-link disabled">« Prev</span>
                                <% } %>

                                    <% const startPage=Math.max(1, currentPage - 2); const endPage=Math.min(totalPages,
                                        currentPage + 2); %>

                                        <% if (startPage> 1) { %>
                                            <a href="/admin/return-requests?page=1&search=<%= encodeURIComponent(search || '') %>"
                                                class="pagination-link">1</a>
                                            <% if (startPage> 2) { %>
                                                <span class="pagination-link disabled">...</span>
                                                <% } %>
                                                    <% } %>

                                                        <% for (let i=startPage; i <=endPage; i++) { %>
                                                            <% if (i===currentPage) { %>
                                                                <span class="pagination-link current">
                                                                    <%= i %>
                                                                </span>
                                                                <% } else { %>
                                                                    <a href="/admin/return-requests?page=<%= i %>&search=<%= encodeURIComponent(search || '') %>"
                                                                        class="pagination-link">
                                                                        <%= i %>
                                                                    </a>
                                                                    <% } %>
                                                                        <% } %>

                                                                            <% if (endPage < totalPages) { %>
                                                                                <% if (endPage < totalPages - 1) { %>
                                                                                    <span
                                                                                        class="pagination-link disabled">...</span>
                                                                                    <% } %>
                                                                                        <a href="/admin/return-requests?page=<%= totalPages %>&search=<%= encodeURIComponent(search || '') %>"
                                                                                            class="pagination-link">
                                                                                            <%= totalPages %>
                                                                                        </a>
                                                                                        <% } %>

                                                                                            <% if (currentPage <
                                                                                                totalPages) { %>
                                                                                                <a href="/admin/return-requests?page=<%= currentPage + 1 %>&search=<%= encodeURIComponent(search || '') %>"
                                                                                                    class="pagination-link next">Next
                                                                                                    »</a>
                                                                                                <% } else { %>
                                                                                                    <span
                                                                                                        class="pagination-link disabled">Next
                                                                                                        »</span>
                                                                                                    <% } %>

                    </div>
                    <p style="text-align: center; color: #aaa; font-size: 13px; margin-top: 8px;">
                        Page <%= currentPage %> of <%= totalPages %>
                    </p>
                </div>
        </div>
    </div>

    <%- include('../partials/admin/footer') %>