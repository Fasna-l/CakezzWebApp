<%- include('../partials/admin/header') %>
<link rel="stylesheet" href="/css/admin-style/orderlist.css">

<div class="dashboard-container">
    <div class="dashboard-wrapper">
        <%- include('../partials/admin/sidebar') %>
        
        <!-- Main Content -->
        <div class="categories-container">
            <!-- Page Title with Search -->
            <div class="page-title">
                <h2>Return Requests</h2>

                <form action="/admin/return-requests" method="get" class="search-form">
                    <div class="search-box">
                        <input type="text" 
                        class="search-input" 
                        placeholder="Search by order id / product / user..." 
                        name="search" 
                        value="<%= search || '' %>">

                        <button class="search-button-text" type="submit">Search</button>    

                        <% if (search && search.trim() !== '') { %>
                            <a href="/admin/return-requests" class="clear-btn">Clear</a>
                        <% } %>
                    </div>
                </form>

            </div>

            <!-- Table -->
            <div class="table-wrapper">
                <table class="customers-table">
                    <thead>
                        <tr>
                            <th>ORDER ID</th>
                            <th>USER NAME</th>
                            <th>PRODUCT NAME</th>
                            <th>DATE</th>
                            <th>QTY</th>
                            <th>STATUS</th>
                            <th>ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (requests && requests.length > 0) { %>

                            <% 
                            // GROUP ITEMS BY ORDER ID
                                let grouped = {};
                                requests.forEach(r => {
                                if (!grouped[r.orderId]) grouped[r.orderId] = [];
                                grouped[r.orderId].push(r);
                                });
                            %>

                            <% Object.keys(grouped).forEach(orderId => { 
                                const items = grouped[orderId];
                                const first = items[0];
                            %>

                            <!-- MAIN ROW (ONE PER ORDER) -->
                            <tr style="background:#37383a; font-weight:600;">
                                <td><%= first.orderId %></td>
                                <td><%= first.userName %></td>
                                <td colspan="3">Multiple Items Returned</td>
                                <td>
                                    <span class="status-badge processing">Return Requested</span>
                                </td>
                                <td>
                                <!-- WHOLE ORDER BUTTONS (ONLY ONCE) -->
                                    <a href="/admin/order/<%= first.orderDbId %>/approve-whole-return"
                                        class="btn-edit"
                                        style="display:block; margin-bottom:6px; padding:6px 10px; border-radius:6px; background:#2e7d32; color:#fff;">
                                        Approve Full Order Return
                                    </a>

                                    <a href="/admin/order/<%= first.orderDbId %>/reject-whole-return"
                                        class="btn-edit"
                                        style="display:block; padding:6px 10px; border-radius:6px; background:#b71c1c; color:#fff;">
                                        Reject Full Order Return
                                    </a>

                                    <a href="/admin/order-details/<%= first.orderDbId %>"
                                        class="btn-edit"
                                        style="display:block; margin-top:6px; padding:6px 10px; border-radius:6px; background:#666; color:#fff;">
                                        View Order
                                    </a>
                                </td>
                            </tr>

                            <!-- CHILD ROWS — EACH ITEM INSIDE THE ORDER -->
                            <% items.forEach(item => { %>
                                <tr class="sub-item-row">
                                <td></td>
                                <td></td>
                                <td><%= item.productName %></td>
                                <td><%= new Date(item.orderDate).toLocaleDateString("en-GB") %></td>
                                <td><%= item.quantity %></td>
                                <td>
                                    <span class="status-badge processing"><%= item.status %></span>
                                </td>
                                <td>
                                <!-- SINGLE ITEM BUTTONS -->
                                    <a href="/admin/order/<%= item.orderDbId %>/item/<%= item.itemId %>/approve-return"
                                        class="btn-edit"
                                        style="margin-right:8px; padding:6px 10px; border-radius:6px; background:#2d8bff; color:#fff;">
                                        Approve
                                    </a>

                                    <a href="/admin/order/<%= item.orderDbId %>/item/<%= item.itemId %>/reject-return"
                                        class="btn-edit"
                                        style="padding:6px 10px; border-radius:6px; background:#c62828; color:#fff;">
                                        Reject
                                    </a>
                                </td>
                            </tr>
                        <% }) %>

                    <!-- DIVIDER -->
                    <tr><td colspan="7" style="height:10px; background:#eee;"></td></tr>

                    <% }) %>

                    <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align:center;">No return requests found</td>
                    </tr>
                <% } %>
                </tbody>

                </table>
            </div>

            <!-- Pagination -->
            <div class="pagination-container">
                <% if (currentPage > 1) { %>
                    <a href="/admin/return-requests?page=<%= currentPage - 1 %>&search=<%= encodeURIComponent(search || '') %>" class="pagination-link prev">« Prev</a>
                <% } else { %>
                    <span class="pagination-link disabled">« Prev</span>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <% if (i === currentPage) { %>
                        <span class="pagination-link current"><%= i %></span>
                    <% } else { %>
                        <a href="/admin/return-requests?page=<%= i %>&search=<%= encodeURIComponent(search || '') %>" class="pagination-link"><%= i %></a>
                    <% } %>
                <% } %>

                <% if (currentPage < totalPages) { %>
                    <a href="/admin/return-requests?page=<%= currentPage + 1 %>&search=<%= encodeURIComponent(search || '') %>" class="pagination-link next">Next »</a>
                <% } else { %>
                    <span class="pagination-link disabled">Next »</span>
                <% } %>
            </div>

            <p style="text-align: center; color: #aaa; font-size: 13px; margin-top: 8px;">
                Page <%= currentPage %> of <%= totalPages %>
            </p>
        </div>
    </div>
</div>

<%- include('../partials/admin/footer') %>
