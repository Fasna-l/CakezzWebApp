<%- include('../partials/admin/header') %>
<link rel="stylesheet" href="/css/admin-style/login.css">


<div class="admin-login-container">
    <!-- <div class="login-page-title">Login</div> -->
    
    <div class="admin-login-card">
        <h2 class="admin-login-title">Admin login</h2>

         <%if(locals.message && message.length>0){%>
            <div class="alert alert-danger text-center">
        <%=message%>
            </div>
        <%}%>
        
        <form class="admin-login-form" method="POST" action="/admin/login">
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input 
                    type="email" 
                    class="form-control admin-input" 
                    id="email" 
                    name="email" 
                    placeholder="Email" 
                    required
                >
            </div>
            
            <div class="form-group">
                <label for="password" class="form-label">Password</label>
                <input 
                    type="password" 
                    class="form-control admin-input" 
                    id="password" 
                    name="password" 
                    placeholder="Password" 
                    required
                >
            </div>
            
            <button type="submit" class="admin-login-btn">Login</button>
        </form>
    </div>
</div>

<%- include('../partials/admin/footer') %>