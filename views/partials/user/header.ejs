<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cakez.in - Delicious Cakes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/user-style/home.css" />

  <!--Toast link-->
  <link rel="stylesheet" href="/css/user-style/toast.css">
  <script src="/js/toast.js" defer></script>
  <!--addtocart common function-->
  <script src="/js/addToCart.js" defer></script>


  
</head>
<body>
  <!--==================== HEADER SECTION ====================-->  
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="#">
        <i class="fas fa-birthday-cake"></i> Cakez.in
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav mx-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#">About</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/shop">Shop</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#">Contact</a>
          </li>
        </ul>

        <div class="header-icons">
          <i class="fas fa-search"></i>
          <div class="user-dropdown">
            <i class="fas fa-user"></i>
            <div class="user-dropdown-menu">
              <% if(locals.user) { %>
                <div class="dropdown-header">
                  <h4>Hi, <%= locals.user.name %> </h4>
                  <p>Welcome back!</p>
                </div>

                <div class="dropdown-menu-items">
                <a href="/account" class="dropdown-menu-item">My Account</a>
                <a href="/order" class="dropdown-menu-item">My Orders</a>
                <a href="/address" class="dropdown-menu-item">My Address Book</a>
                <a href="/wallet" class="dropdown-menu-item">My Wallet</a>
                <a href="/logout" class="dropdown-menu-item">Logout</a>
              </div>
              <!--Show when no user is logged in -->
              <% } else { %>
                <div class="dropdown-header">
                <h4>Welcome</h4>
                <p>To access account and manage orders</p>
                <div class="dropdown-buttons">
                  <a href="/login" class="dropdown-login-btn">Login</a>
                  <a href="/signup" class="dropdown-login-btn">Signup</a>
                </div>
              </div>
              <% } %>

            </div>
          </div>
          <i class="fas fa-heart"></i>
          <div class="cart-icon-wrapper" onclick="window.location.href='/cart'">
            <i class="fas fa-shopping-cart"></i>
            <span id="cart-count"><%= typeof cartCount !== 'undefined' ? cartCount : 0 %></span>
          </div>

        </div>
      </div>
    </div>
  </nav>
